# RunixOS uses custom library extensions:
#   .rdl = RunixOS Dynamic Library (shared)
#   .ral = RunixOS Archive Library (static)
shared-lib-ext = .rdl
static-lib-ext = .ral

# RunixOS has no separate sbin — everything goes to bindir.
sbindir = $(bindir)
rootsbindir = $(bindir)

# RunixOS renames ld.so.conf → LibKit.conf
# ld.so.cache → LibKit.cache is handled via sysdeps/unix/sysv/runixos/dl-cache.h
CFLAGS-.o += -DLD_SO_CONF='\"$(sysconfdir)/LibKit.conf\"'
CFLAGS-.os += -DLD_SO_CONF='\"$(sysconfdir)/LibKit.conf\"'
